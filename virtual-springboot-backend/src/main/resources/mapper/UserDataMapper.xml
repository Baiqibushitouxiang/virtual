<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.sustbbgz.virtualspringbootbackend.mapper.UserDataMapper">

    <!-- 基本字段映射 -->
    <resultMap id="BaseResultMap" type="com.sustbbgz.virtualspringbootbackend.entity.UserData">
        <id column="id" property="id" />
        <result column="user_id" property="user.id" />
        <result column="user_info" property="userInfo" />
        <result column="created_at" property="createdAt" />
        <result column="updated_at" property="updatedAt" />
    </resultMap>

    <!-- 字段列表，供复用 -->
    <sql id="Base_Column_List">
        id, user_id, user_info, created_at, updated_at
    </sql>

    <!-- 查找所有用户数据 -->
    <select id="findAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List" />
        FROM userdata
    </select>

    <!-- 通过 ID 查找用户数据 -->
    <select id="findById" resultMap="BaseResultMap" parameterType="long">
        SELECT <include refid="Base_Column_List" />
        FROM userdata
        WHERE user_id = #{id}
    </select>

    <!-- 插入用户数据 -->
    <insert id="save" parameterType="com.sustbbgz.virtualspringbootbackend.entity.UserData" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO userdata (user_id, user_info)
        VALUES (#{user.id}, #{userInfo})
    </insert>

    <!-- 更新用户数据 -->
    <update id="update" parameterType="com.sustbbgz.virtualspringbootbackend.entity.UserData">
        UPDATE userdata
        SET user_info = #{userInfo}
        WHERE id = #{id}
    </update>

</mapper>
