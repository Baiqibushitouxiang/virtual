<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.sustbbgz.virtualspringbootbackend.mapper.UserMapper">
    <resultMap id="BaseResultMap" type="com.sustbbgz.virtualspringbootbackend.entity.User">
        <id column="id" property="id" />
        <result column="username" property="username" />
        <result column="password" property="password" />
        <result column="email" property="email" />
        <result column="phone" property="phone" />
        <result column="role" property="role" />
        <result column="is_deleted" property="is_deleted" />
    </resultMap>

    <resultMap id="pageUser" type="com.sustbbgz.virtualspringbootbackend.entity.User">
        <id column="id" property="id" />
        <result column="username" property="username" />
        <result column="password" property="password" />
        <result column="email" property="email" />
        <result column="phone" property="phone" />
        <result column="role" property="role" />
    </resultMap>

    <select id="findPage" resultMap="pageUser">
        select id,username,password,email,phone,role from Users
        <where>
            is_deleted = FALSE
            <if test="username != null and username != ''">
                and sys_user.username like concat('%', #{username} ,'%')
            </if>
            <if test="email != null and email != ''">
                and sys_user.email like concat('%', #{email} ,'%')
            </if>
        </where>
    </select>

    <sql id="Base_Column_List">
        id, username, password, email, phone, role, is_deleted
    </sql>

    <select id="findAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List" /> FROM Users WHERE is_deleted = FALSE
    </select>

    <select id="findById" resultMap="BaseResultMap" parameterType="long">
        SELECT <include refid="Base_Column_List" /> FROM Users WHERE id = #{id} AND is_deleted = FALSE
    </select>

    <insert id="save" parameterType="com.sustbbgz.virtualspringbootbackend.entity.User" useGeneratedKeys="true" keyProperty="id">

        INSERT INTO Users (username, password, email,phone,role,is_deleted)
        VALUES (#{username}, #{password}, #{email},#{phone},#{role},#{is_deleted})
    </insert>

    <update id="update" parameterType="com.sustbbgz.virtualspringbootbackend.entity.User">
        UPDATE Users
        SET username=#{username}, password=#{password}, email=#{email}, phone=#{phone}, role=#{role}
        WHERE id = #{id}
    </update>

    <update id="deleteById" parameterType="long">
        UPDATE Users SET is_deleted = TRUE WHERE id = #{id}
    </update>

    <select id="findByUsernameAndPassword" resultMap="BaseResultMap" parameterType="com.sustbbgz.virtualspringbootbackend.controller.dto.UserDTO">
        SELECT <include refid="Base_Column_List" /> FROM Users WHERE username = #{username} AND password = #{password}
    </select>

    <select id="findByUsername" resultMap="BaseResultMap" parameterType="String">
        SELECT <include refid="Base_Column_List" /> FROM Users WHERE username = #{username} AND is_deleted = FALSE
    </select>

</mapper>
